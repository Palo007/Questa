# =============================================================================
# Questa - Whitelist .gitignore
# Only files from the reference repo (https://github.com/Palo007/Questa)
# are tracked. Everything else is ignored.
# =============================================================================

# Ignore everything at the root level
/*
!/.gitignore

# === Questa reference repo files (only these should ever be tracked) ===
!/INSTALL.md
!/app.js
!/habitica_to_questa.py
!/icon-192.png
!/icon-512.png
!/icon.svg
!/index.html
!/manifest.json
!/sw.js

# === OS cruft ===
.DS_Store
Thumbs.db
desktop.ini

# === Editor / IDE ===
.vscode/
.idea/
*.swp

# === Logs / temp ===
*.log
*.tmp

# === Python cache ===
__pycache__/
*.pyc

# === Archives and backups ===
*.bak
*.bak-*
*.7z
*.zip
